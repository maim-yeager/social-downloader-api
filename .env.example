# ======================================================
# Universal Social Media Downloader API - Environment
# ======================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# API Security
# Set to "true" to require API key authentication on all requests
REQUIRE_API_KEY=false

# Comma-separated list of valid API keys
# Generate strong random keys for production!
# Example: openssl rand -hex 32
API_KEYS=your-secret-api-key-here,another-key-if-needed

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100   # Max requests per window per IP

# Cache Configuration
CACHE_TTL_SECONDS=300         # How long to cache results (5 minutes)
CACHE_MAX_KEYS=500            # Maximum number of cached entries

# Request Timeouts
EXTRACTION_TIMEOUT_MS=30000   # 30 seconds max for extraction

# Instagram Session Cookie (optional, for private content)
# Get from browser DevTools → Application → Cookies → instagram.com
INSTAGRAM_SESSION_ID=

# TikTok Session Cookie (optional, for private content)
TIKTOK_SESSION_ID=

# YouTube API Key (optional, enhances metadata quality)
YOUTUBE_API_KEY=

# Allowed Origins for CORS (comma-separated, * for all)
ALLOWED_ORIGINS=*

# Logging Level: error | warn | info | debug
LOG_LEVEL=info
